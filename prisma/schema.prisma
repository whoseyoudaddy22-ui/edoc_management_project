// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SARABAN // เจ้าหน้าที่สารบรรณ (ค่าเริ่มต้นตาม mockup)
  ADMIN
  APPROVER
  VIEWER
}

enum TitlePrefix {
  MR
  MRS
  MISS
}

// ฝ่ายงานขององค์กร (จัดหมวดพนักงานในทำเนียบผู้ใช้งาน) — คนละเรื่องกับ User.departmentCode
// ซึ่งเป็นรหัสย่อหน่วยงานผู้ออกเอกสารที่ใช้ในระบบเลขที่เอกสารอัตโนมัติ (ดู skill document-numbering)
enum Division {
  ADMINISTRATION
  HR
  FINANCE_ACCOUNTING
  MARKETING
  SALES
  IT
  CUSTOMER_SERVICE
}

enum Priority {
  NORMAL
  URGENT
  VERY_URGENT
  IMMEDIATE
}

// ข้อความปิดท้ายก่อนช่องลงนาม ค่า default ขึ้นกับ documentTypeCode ที่เลือกตอนสร้างเอกสาร
// (ดู .claude/skills/official-document-template/SKILL.md ส่วน "บันทึกข้อความ (variant)")
enum ClosingText {
  THANK_YOU_INFORM // "จึงเรียนมาเพื่อทราบ และดำเนินการตามอำนาจและหน้าที่ต่อไป" — default ของบันทึกข้อความ
  RESPECTFULLY // "ขอแสดงความนับถือ" — default ของหนังสือภายนอกและประเภทอื่น
}

enum DocumentStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum AuditAction {
  DOCUMENT_CREATE
  DOCUMENT_UPDATE
  DOCUMENT_STATUS_CHANGE
  DOCUMENT_DELETE
  ATTACHMENT_UPLOAD
  ATTACHMENT_DELETE
  DOCUMENT_PRINT
  USER_LOGIN
  USER_LOGOUT
  USER_LOGIN_FAILED
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  name           String // ชื่อเต็มคำนวณจาก titlePrefix+firstName+lastName เก็บไว้ใช้แสดงผลจุดอื่นในระบบ (เอกสาร, sidebar, audit log ฯลฯ)
  titlePrefix    TitlePrefix?
  firstName      String?
  lastName       String?
  division       Division? // ฝ่ายงาน (ข้อมูลทำเนียบผู้ใช้งาน) — nullable เพื่อไม่กระทบบัญชีเดิมที่มีอยู่ก่อน field นี้
  position       String? // ตำแหน่งงาน ใช้เติมอัตโนมัติในช่อง "ตำแหน่งผู้ลงนาม" ของเอกสารได้ในอนาคต
  role           Role         @default(SARABAN)
  departmentCode String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  createdDocuments  Document[]   @relation("DocumentCreatedBy")
  approvedDocuments Document[]   @relation("DocumentApprovedBy")
  attachments       Attachment[]
  auditLogs         AuditLog[]
  passwordResetTokens PasswordResetToken[]
}

model DocumentType {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
}

model Document {
  id                String         @id @default(cuid())
  documentNumber    String         @unique
  departmentCode    String
  departmentName    String? // ชื่อเต็มส่วนราชการ + เบอร์โทร แสดงที่หัวเอกสาร คนละความหมายกับ departmentCode (ใช้ในเลขที่เอกสารอัตโนมัติ)
  documentTypeId    String
  documentTypeCode  String
  buddhistYear      Int
  runningNumber     Int
  documentDate      DateTime
  title             String
  priority          Priority       @default(NORMAL)
  recipient         String
  sender            String
  referenceNumber   String?
  content           String
  closingText       ClosingText?   @default(RESPECTFULLY)
  status            DocumentStatus @default(DRAFT)
  signerName        String?
  signerPosition    String?
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  documentType DocumentType @relation(fields: [documentTypeId], references: [id])
  createdBy    User         @relation("DocumentCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?        @relation("DocumentApprovedBy", fields: [approvedById], references: [id])
  attachments  Attachment[]

  @@unique([buddhistYear, documentTypeCode, departmentCode, runningNumber])
  @@index([documentTypeCode])
  @@index([status])
  @@index([createdAt])
  @@index([departmentCode])
  @@index([createdById])
}

model Attachment {
  id           String   @id @default(cuid())
  documentId   String
  fileName     String
  filePath     String
  fileType     String
  fileSize     Int
  uploadedById String
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id])
  uploadedBy User     @relation(fields: [uploadedById], references: [id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  performedBy String
  targetType  String // เช่น "Document", "User", "Attachment"
  targetId    String
  changes     Json? // { field: { from: ..., to: ... } } เฉพาะกรณี UPDATE
  ipAddress   String?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [performedBy], references: [id])

  @@index([targetType, targetId])
  @@index([performedBy])
  @@index([createdAt])
}
